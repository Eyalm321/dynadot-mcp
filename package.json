{
  "name": "@eyalm321/dynadot-mcp",
  "version": "1.0.1",
  "description": "MCP server for Dynadot RESTful API v2 — tools for domain registration, DNS, contacts, nameservers, folders, aftermarket, and more",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "dynadot-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "dynadot",
    "domains",
    "dns",
    "claude",
    "model-context-protocol",
    "registrar"
  ],
  "author": "Eyalm321",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eyalm321/dynadot-mcp.git"
  },
  "homepage": "https://github.com/Eyalm321/dynadot-mcp#readme",
  "bugs": {
    "url": "https://github.com/Eyalm321/dynadot-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
